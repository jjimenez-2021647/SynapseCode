# ServicePlans Port Configuration
PORT=3013
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/synapsecode_plans

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_ISSUER=SynapseCode
JWT_AUDIENCE=SynapseCode-Users

# AuthService Bridge
AUTH_SERVICE_URL=http://localhost:3006

# Email SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_FROM_EMAIL=noreply@synapsecode.com
FRONTEND_URL=http://localhost:3000

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Plan Pricing (in USD cents, multiply by 100)
# FREE = $0, PRO = $20/month, ORG = $50/month
PLAN_FREE_PRICE=0
PLAN_PRO_PRICE=2000
PLAN_ORG_PRICE=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
