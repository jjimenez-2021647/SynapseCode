  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Check if token exists, warn if missing",
          "const token = pm.environment.get('adminToken');",
          "if (!token && !pm.request.url.toString().includes('/health') && !pm.request.url.toString().includes('/auth/login')) {",
          "    console.warn(\"⚠️ No adminToken found. Authentication may fail. Run Auth requests first or set token manually.\");",
          "}",
          "",
          "// Log current request",
          "console.log(`🔄 Executing: ${pm.info.requestName}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Common error handling",
          "if (pm.response.code === 401) {",
          "    pm.test(\"⚠️ Unauthorized - Check token\", () => {",
          "        console.error(\"Token missing or invalid. Run Auth requests or set token manually.\");",
          "    });",
          "}",
          "",
          "if (pm.response.code === 403) {",
          "    pm.test(\"⚠️ Forbidden - Check permissions\", () => {",
          "        console.warn(\"User role doesn't have permission for this operation.\");",
          "    });",
          "}",
          "",
          "if (pm.response.code === 500) {",
          "    pm.test(\"❌ Server Error\", () => {",
          "        console.error(\"Internal server error:\", pm.response.json());",
          "    });",
          "}"
        ]
      }
    }
  ]
